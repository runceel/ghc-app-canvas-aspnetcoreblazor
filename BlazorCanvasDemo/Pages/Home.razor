@page "/"
@implements IDisposable
@inject DisplayLanguageService Text

<PageTitle>@Text.T("PageTitle")</PageTitle>

<section class="page-hero">
    <p class="eyebrow">@Text.T("OverviewNav")</p>
    <h2>@Text.T("OverviewTitle")</h2>
    <p>@Text.T("OverviewIntro")</p>
</section>

<div class="page-grid">
    <NavLink class="nav-card" href="actions">
        <span>1</span>
        <strong>@Text.T("ActionsNav")</strong>
        <p>@Text.T("UseActionsPage")</p>
    </NavLink>

    <NavLink class="nav-card" href="monitor">
        <span>2</span>
        <strong>@Text.T("MonitorNav")</strong>
        <p>@Text.T("WatchMonitorPage")</p>
    </NavLink>
</div>

<section class="card">
    <h3>@Text.T("FeatureGuide")</h3>
    <div class="feature-list">
        <article>
            <strong>@Text.T("AiToBlazor")</strong>
            <p>@Text.T("AiToBlazorDescription")</p>
        </article>
        <article>
            <strong>@Text.T("BlazorToCopilot")</strong>
            <p>@Text.T("BlazorToCopilotDescription")</p>
        </article>
        <article>
            <strong>@Text.T("BlazorToExtension")</strong>
            <p>@Text.T("BlazorToExtensionDescription")</p>
        </article>
        <article>
            <strong>@Text.T("OpenReload")</strong>
            <p>@Text.T("OpenReloadDescription")</p>
        </article>
    </div>
</section>

<section class="card">
    <h3>@Text.T("CanvasActionsToTry")</h3>
    <dl class="state-list">
        <dt><code>set-message</code></dt>
        <dd>@Text.T("TryActionsDescription_set-message")</dd>
        <dt><code>append-event</code></dt>
        <dd>@Text.T("TryActionsDescription_append-event")</dd>
        <dt><code>reload</code></dt>
        <dd>@Text.T("TryActionsDescription_reload")</dd>
    </dl>
</section>

@code {
    protected override void OnInitialized()
    {
        Text.Changed += OnLanguageChanged;
    }

    public void Dispose()
    {
        Text.Changed -= OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
