@page "/"
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Copilot Canvas Chat</PageTitle>

<div class="canvas-chat">
    <h1>Copilot Canvas Chat</h1>
    <p>
        Send a prompt from this Blazor UI. The canvas extension forwards it to Copilot AI
        and returns the response here.
    </p>

    <div class="chat-log" role="log" aria-live="polite" aria-label="Chat transcript">
        @foreach (var message in _messages)
        {
            <article class="chat-message @message.RoleClass">
                <header>@message.SenderLabel</header>
                <p>@message.Text</p>
            </article>
        }

        @if (_isSending)
        {
            <article class="chat-message assistant pending">
                <header>AI</header>
                <p>Thinking...</p>
            </article>
        }
    </div>

    <EditForm Model="_promptForm" OnValidSubmit="SendPromptAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <label for="promptBox">Message</label>
        <InputTextArea id="promptBox"
                       class="prompt-box"
                       @bind-Value="_promptForm.Prompt"
                       rows="4" />
        <button type="submit" disabled="@(_isSending || string.IsNullOrWhiteSpace(_promptForm.Prompt))">
            Send to AI
        </button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="error-message">@_errorMessage</p>
    }
</div>

@code {
    private readonly PromptForm _promptForm = new();
    private readonly List<ChatMessage> _messages = new()
    {
        new("assistant", "AI", "Hello! Ask me anything from this canvas chat."),
    };

    private bool _isSending;
    private string? _errorMessage;

    private async Task SendPromptAsync()
    {
        var prompt = _promptForm.Prompt.Trim();
        if (string.IsNullOrWhiteSpace(prompt))
        {
            return;
        }

        _messages.Add(new("user", "You", prompt));
        _promptForm.Prompt = string.Empty;
        _errorMessage = null;
        _isSending = true;

        try
        {
            using var response = await Http.PostAsJsonAsync("/api/chat", new ChatRequest(prompt));
            var payload = await response.Content.ReadFromJsonAsync<ChatResponse>();

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = payload?.Error ?? $"Chat request failed with status {(int)response.StatusCode}.";
                return;
            }

            if (string.IsNullOrWhiteSpace(payload?.Reply))
            {
                _errorMessage = "AI response was empty.";
                return;
            }

            _messages.Add(new("assistant", "AI", payload.Reply.Trim()));
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Could not reach the canvas chat endpoint: {ex.Message}";
        }
        catch (TaskCanceledException)
        {
            _errorMessage = "The chat request timed out.";
        }
        catch (JsonException ex)
        {
            _errorMessage = $"Invalid JSON response from the chat endpoint: {ex.Message}";
        }
        finally
        {
            _isSending = false;
        }
    }

    private sealed record ChatRequest(string Prompt);

    private sealed record ChatResponse(string? Reply, string? Error);

    private sealed record ChatMessage(string RoleClass, string SenderLabel, string Text);

    private sealed class PromptForm
    {
        [Required]
        [StringLength(4000)]
        public string Prompt { get; set; } = string.Empty;
    }
}

<style>
    .canvas-chat {
        font-family: var(--font-sans, system-ui, sans-serif);
        padding: 1rem;
        display: grid;
        gap: 0.75rem;
        color: var(--text-color-default, #1f2328);
        background: var(--background-color-default, #ffffff);
    }

    .chat-log {
        border: 1px solid var(--border-color-default, #d0d7de);
        border-radius: 6px;
        background: var(--background-color-default, #ffffff);
        min-height: 220px;
        max-height: 420px;
        overflow-y: auto;
        padding: 0.75rem;
        display: grid;
        gap: 0.75rem;
    }

    .chat-message {
        border: 1px solid var(--border-color-default, #d0d7de);
        border-left-width: 4px;
        border-radius: 6px;
        padding: 0.625rem 0.75rem;
        background: var(--background-color-default, #ffffff);
        color: var(--text-color-default, #1f2328);
    }

    .chat-message header {
        font-size: 0.8125rem;
        font-weight: 600;
        margin-bottom: 0.375rem;
        color: var(--text-color-default, #1f2328);
    }

    .chat-message p {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        color: var(--text-color-default, #1f2328);
    }

    .chat-message.user {
        border-left-color: var(--true-color-blue, #0969da);
    }

    .chat-message.assistant {
        border-left-color: var(--border-color-default, #d0d7de);
    }

    .chat-message.pending {
        opacity: 0.8;
        font-style: italic;
    }

    .prompt-box {
        width: 100%;
        box-sizing: border-box;
        margin-top: 0.25rem;
        margin-bottom: 0.5rem;
        border: 1px solid var(--border-color-default, #d0d7de);
        border-radius: 6px;
        padding: 0.5rem 0.625rem;
        font: inherit;
        color: var(--text-color-default, #1f2328) !important;
        background-color: var(--background-color-default, #ffffff) !important;
        caret-color: var(--text-color-default, #1f2328) !important;
        resize: vertical;
    }

    .prompt-box::placeholder {
        color: var(--text-color-muted, #656d76);
        opacity: 1;
    }

    .prompt-box:focus {
        outline: 2px solid var(--color-focus-outline, #0969da);
        outline-offset: 1px;
    }

    .prompt-box:disabled {
        color: var(--text-color-muted, #656d76);
        background-color: var(--background-color-default, #ffffff);
        opacity: 1;
    }

    button[type="submit"] {
        border: 1px solid #1f883d;
        border-radius: 6px;
        background: #1f883d;
        color: #ffffff;
        padding: 0.5rem 0.875rem;
        font-weight: 600;
        cursor: pointer;
    }

    button[type="submit"]:disabled {
        cursor: not-allowed;
        opacity: 0.7;
    }

    .error-message {
        margin: 0;
        color: #cf222e;
        font-weight: 600;
    }
</style>
